{
  "name": "stock-monitor-frontend",
  "private": true,
  "version": "0.4.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "lint": "eslint src/ --max-warnings 0 && prettier --check \"src/**/*.{ts,vue,css}\"",
    "lint:fix": "eslint src/ --fix && prettier --write \"src/**/*.{ts,vue,css}\"",
    "format": "prettier --write \"src/**/*.{ts,vue,css}\""
  },
  "dependencies": {
    "vue": "^3.5.0",
    "vue-router": "^4.3.0",
    "pinia": "^2.1.7",
    "naive-ui": "^2.38.0",
    "echarts": "^5.5.0",
    "vue-echarts": "^7.0.0",
    "axios": "^1.7.2",
    "@vicons/ionicons5": "^0.12.0"
  },
  "devDependencies": {
    "vite": "^8.1.4",
    "@vitejs/plugin-vue": "^6.0.7",
    "typescript": "^7.0.2",
    "vue-tsc": "^3.3.7",
    "@types/node": "^20.14.0",
    "vitest": "^2.0.0",
    "@vue/test-utils": "^2.4.0",
    "jsdom": "^24.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^9.28.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "vue-eslint-parser": "^9.4.0",
    "prettier": "^3.3.0"
  }
}
